# Postgres connection string (Neon / any Postgres). sslmode=require is expected.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Force a full re-import even if the WCA export_date hasn't changed.
# Leave unset in normal use.
# FORCE_INGEST=1

# Skip the derive stage. Leaves raw_wca fresh but doesn't rebuild app.*
# or current_ratings. Useful for debugging the WCA import in isolation.
# SKIP_DERIVE=1
