{
  "name": "speedcuberatings",
  "private": true,
  "version": "0.0.0",
  "description": "Performance-rating leaderboard for speedcubing, derived from official WCA results. Rating model by James Macdiarmid.",
  "license": "MIT",
  "homepage": "https://github.com/speedcuberatings/speedcuberatings",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/speedcuberatings/speedcuberatings.git"
  },
  "bugs": {
    "url": "https://github.com/speedcuberatings/speedcuberatings/issues"
  },
  "keywords": [
    "speedcubing",
    "rubiks-cube",
    "wca",
    "leaderboard",
    "ratings"
  ],
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ingest": "pnpm --filter @scr/ingest run ingest",
    "ingest:check": "pnpm --filter @scr/ingest run check",
    "web": "pnpm --filter @scr/web run dev"
  }
}
